# =============================================================================
# Sentinel — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@postgres:5432/sentinel

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LLM Provider API Keys ---
# At least one is required for the gateway to forward requests.
# Tip for students: set a hard spend cap (e.g. $5–10) in each provider
# dashboard so a runaway loop can't burn through your free trial credits.
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here


# OpenRouter — single key, access to many models (Llama, Mistral, Gemini, etc.)
# Some routes are free; useful when OpenAI/Anthropic credits run low.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_REFERER=https://github.com/Siddharthpatni/Sentinel
OPENROUTER_TITLE=Sentinel

# --- Sentinel ---
# The API key used by SDK callers to authenticate with the gateway.
# A default project with this key is auto-seeded on first boot.
DEFAULT_PROJECT_API_KEY=sk-sentinel-dev-000

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000
